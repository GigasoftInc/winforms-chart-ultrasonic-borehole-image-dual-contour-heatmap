<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>x64</Platforms>
    <NoWarn>$(NoWarn);NETSDK1206</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ProEssentials.Chart.Net80.x64.Winforms" Version="[10.0.0.28,11.0.0)" />
  </ItemGroup>

  <!-- Copy native DLL to output directory -->
  <Target Name="CopyNativeDll" AfterTargets="Build">
    <Copy SourceFiles="$(OutDir)runtimes\win7-x64\native\PEGRP64H.DLL" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Copy UBI test data files to output directory -->
  <ItemGroup>
    <Content Include="TestData_FORGE_AWCN_clipped.txt"><CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory></Content>
    <Content Include="TestData_FORGE_TTCN_clipped.txt"><CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory></Content>
  </ItemGroup>

</Project>
